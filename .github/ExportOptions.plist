<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- Distribution method: app-store submits to App Store Connect. -->
    <key>method</key>
    <string>app-store</string>

    <!--
        Your 10-character Apple Developer Team ID.
        In CI this is replaced at runtime by release.yml from the APPLE_TEAM_ID secret.
        For local export: replace XXXXXXXXXX with your actual team ID.
    -->
    <key>teamID</key>
    <string>XXXXXXXXXX</string>

    <!--
        Automatic (cloud) signing: Xcode generates the App Store distribution
        provisioning profiles on the fly using the App Store Connect API key that
        release.yml passes to xcodebuild (-allowProvisioningUpdates + the
        -authenticationKey* flags). No manual .provisionprofile files are needed.
    -->
    <key>signingStyle</key>
    <string>automatic</string>

    <!-- Bitcode is not supported on macOS. -->
    <key>uploadBitcode</key>
    <false/>
    <key>compileBitcode</key>
    <false/>

    <!--
        Strip Swift standard-library symbols from the binary to reduce bundle size.
        Set to false only if you need on-device symbolication of production crashes
        without a separately uploaded dSYM bundle.
    -->
    <key>stripSwiftSymbols</key>
    <true/>

</dict>
</plist>
