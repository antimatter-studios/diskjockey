.DS_Store
.build
build/
project.xcworkspace
xcuserdata/
*.profraw
diskjockey-backend/diskjockey-backend
diskjockey-cli/diskjockey-cli
diskjockey-backend/test-mount/ftp-server/
diskjockey-backend/test-mount/sftp-server/
diskjockey-backend/test-mount/smb-server/
diskjockey-backend/test-mount/webdav-server/
diskjockey-backend/test-mount/mount*/

# Vendored third-party build outputs (rebuilt via make)
# Note: Source directories (*-src/, diskjockey-backend/) ARE tracked
# Only ignore the build output directories
vendor/fs_ext4/*
!vendor/fs_ext4/.gitkeep
vendor/built/*
!vendor/built/.gitkeep
