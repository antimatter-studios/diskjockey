<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      launchd config consumed by SMAppService.daemon(plistName:).
      Lives at <App>.app/Contents/Library/LaunchDaemons/<plist>.
      `BundleProgram` is interpreted RELATIVE to the parent .app
      bundle, NOT to /Library/LaunchDaemons — that's the SMAppService
      contract, different from the legacy SMJobBless layout where
      paths were absolute.
    -->
    <key>Label</key>
    <string>com.antimatterstudios.diskjockey.mounthelper</string>

    <key>BundleProgram</key>
    <string>Contents/MacOS/com.antimatterstudios.diskjockey.mounthelper</string>

    <!-- Mach service the helper listens on; same name as `mountHelperMachServiceName`. -->
    <key>MachServices</key>
    <dict>
        <key>com.antimatterstudios.diskjockey.mounthelper</key>
        <true/>
    </dict>

    <!--
      Tells launchd this daemon belongs to the DiskJockey.app bundle
      so System Settings can present a unified "DiskJockey" entry in
      Login Items & Extensions for approval. Without this the helper
      shows up under its own bundle id, confusing.
    -->
    <key>AssociatedBundleIdentifiers</key>
    <array>
        <string>com.antimatterstudios.diskjockey</string>
    </array>
</dict>
</plist>
